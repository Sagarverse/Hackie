rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Signaling mailbox for WebRTC Handshake
    match /signals/{peerId} {
      // Allow creation/updates for the 4-6 char peer IDs
      allow read, write: if peerId.size() >= 4 && peerId.size() <= 6;
      
      // Potential improvement: Anonymous Auth check
      // allow read, write: if request.auth != null;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
