rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Signaling mailbox for WebRTC Handshake
    match /signals/{peerId} {
      // Allow signaling room IDs used by app/web (for example: PIN_1234)
      // while keeping scope limited to sane identifier characters and length.
      allow read, write: if peerId.matches('^[A-Za-z0-9_-]{4,64}$');
      
      // Potential improvement: Anonymous Auth check
      // allow read, write: if request.auth != null;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
